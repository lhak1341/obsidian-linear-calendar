{
	"compilerOptions": {
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES2018",
		"allowJs": true,
		"strict": true,
		"moduleResolution": "bundler",
		"importHelpers": true,
		"isolatedModules": true,
		"lib": ["DOM", "DOM.Iterable", "ES2018", "ES2021.String"]
	},
	"include": ["src/**/*.ts"]
}
